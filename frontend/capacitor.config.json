{
  "appId": "com.readyforguests.connect",
  "appName": "Ready for Guests",
  "webDir": "build",
  "server": {
    "url": "https://rfgsa.onrender.com",
    "cleartext": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0D7377",
      "showSpinner": false
    }
  },
  "android": {
    "buildOptions": {
      "keystorePath": null,
      "keystoreAlias": null
    }
  },
  "ios": {
    "contentInset": "automatic"
  }
}